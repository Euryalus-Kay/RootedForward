# Supabase
#   Required for database-backed features: the research archive, the policy
#   section, form submissions, user accounts, and the admin panel. Copy the
#   values from your Supabase project's API settings page.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mapbox
#   Optional. Enables interactive tour maps. Tour pages fall back to a
#   static map style when this is unset. Create a token at mapbox.com.
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# Resend (transactional email)
#   Required for contact form, volunteer form, and curriculum request
#   delivery. Form submissions send an email to contact@rooted-forward.org
#   via Resend. Without this key, the forms still try to save to Supabase
#   but cannot email; if Supabase is also unconfigured, the form shows a
#   mailto fallback so users can still send their message directly.
#
#   Set up:
#     1. Create an account at resend.com
#     2. Verify the rooted-forward.org domain with DKIM records
#     3. Create an API key with the "Sending access" role
#     4. Paste it below and restart the server
RESEND_API_KEY=re_your_api_key_here

# Site URL (used for sitemap, OG tags, and email links)
NEXT_PUBLIC_SITE_URL=https://rooted-forward.org
